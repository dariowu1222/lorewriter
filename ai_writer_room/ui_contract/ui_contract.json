{
  "version": "0.1",
  "tabs": [
    {
      "id": "manual",
      "label": "省錢模式",
      "mode": "manual",
      "description": "產生 prompt，手動貼到 ChatGPT / Claude / Gemini，再匯回 JSON。",
      "enabled": true
    },
    {
      "id": "openai",
      "label": "API 自動模式",
      "mode": "openai",
      "description": "使用 OpenAI API 自動生成 storyboard。",
      "enabled": true
    }
  ],
  "shared_fields": [
    {
      "id": "sub_genre",
      "label": "子類型",
      "type": "select",
      "required": true,
      "options": [
        "地鐵末班車",
        "宿舍規則",
        "急診夜班",
        "深夜客服",
        "網吧夜班"
      ]
    },
    {
      "id": "world_setting",
      "label": "世界觀",
      "type": "select",
      "required": true,
      "default": "現代都市",
      "options": [
        "現代都市",
        "90年代",
        "近未來",
        "廢棄世界"
      ]
    },
    {
      "id": "horror_style",
      "label": "恐怖類型",
      "type": "select",
      "required": true,
      "default": "規則恐怖",
      "options": [
        "規則恐怖",
        "心理恐怖",
        "認知污染",
        "生存恐怖"
      ]
    },
    {
      "id": "pacing_style",
      "label": "節奏",
      "type": "select",
      "required": true,
      "default": "高壓",
      "options": [
        "慢燒",
        "高壓",
        "爆發型"
      ]
    },
    {
      "id": "ending_style",
      "label": "結局風格",
      "type": "select",
      "required": true,
      "default": "尾刀",
      "options": [
        "尾刀",
        "開放式",
        "絕望",
        "假逃脫"
      ]
    },
    {
      "id": "protagonist_type",
      "label": "主角類型",
      "type": "select",
      "required": true,
      "default": "夜班人員",
      "options": [
        "學生",
        "上班族",
        "警察",
        "醫護",
        "夜班人員"
      ]
    },
    {
      "id": "visual_style",
      "label": "視覺風格",
      "type": "select",
      "required": true,
      "default": "cinematic",
      "options": [
        "anime",
        "cinematic",
        "VHS",
        "realism"
      ]
    },
    {
      "id": "object_focus",
      "label": "核心物件",
      "type": "combobox",
      "required": false,
      "default": "末班車票",
      "placeholder": "選擇或輸入故事核心物件",
      "options": [
        "末班車票",
        "員工證",
        "紅傘",
        "黑色手機",
        "舊鑰匙",
        "病歷夾"
      ]
    },
    {
      "id": "duration",
      "label": "時長秒數",
      "type": "number",
      "required": true,
      "default": 180
    },
    {
      "id": "enable_eval",
      "label": "啟用評估",
      "type": "checkbox",
      "required": false,
      "default": true
    },
    {
      "id": "enable_auto_fix",
      "label": "啟用本地修正",
      "type": "checkbox",
      "required": false,
      "default": false
    },
    {
      "id": "export_render_input",
      "label": "匯出 Render Input",
      "type": "checkbox",
      "required": false,
      "default": true
    },
    {
      "id": "forbidden_words",
      "label": "自訂禁忌詞",
      "type": "textarea",
      "required": false,
      "placeholder": "每行一組：禁忌詞=替換詞"
    }
  ],
  "manual_fields": [],
  "openai_fields": [
    {
      "id": "model",
      "label": "模型",
      "type": "select",
      "required": true,
      "default": "gpt-4o-mini",
      "options": [
        "gpt-4o-mini",
        "gpt-4o"
      ]
    },
    {
      "id": "ignore_budget_guard",
      "label": "忽略成本保護",
      "type": "checkbox",
      "required": false,
      "default": false
    }
  ],
  "shared_actions": [
    {
      "id": "validate_storyboard",
      "label": "驗證 Storyboard",
      "description": "將 JSON 解析並驗證為 Storyboard schema。",
      "requires": [
        "storyboard_json"
      ],
      "outputs": [
        "validated_storyboard"
      ]
    },
    {
      "id": "run_eval",
      "label": "執行評估",
      "description": "執行本地 evaluator，產生規則、禁忌詞、記憶、Arc 與 render 檢查結果。",
      "requires": [
        "validated_storyboard"
      ],
      "outputs": [
        "eval_result_json"
      ]
    },
    {
      "id": "run_auto_fix",
      "label": "執行本地修正",
      "description": "根據 eval 結果執行 deterministic local auto-fix。",
      "requires": [
        "validated_storyboard",
        "eval_result_json"
      ],
      "outputs": [
        "fixed_storyboard_json",
        "after_fix_eval_json"
      ]
    },
    {
      "id": "export_render_input",
      "label": "匯出 Render Input",
      "description": "將 storyboard 轉成 render-friendly JSON。",
      "requires": [
        "validated_storyboard"
      ],
      "outputs": [
        "render_input_json"
      ]
    }
  ],
  "manual_actions": [
    {
      "id": "generate_manual_prompt",
      "label": "產生 Prompt",
      "description": "依使用者設定與規則清單產生可手動貼到 ChatGPT / Claude / Gemini 的 prompt。",
      "requires": [
        "sub_genre",
        "duration",
        "generated_rules"
      ],
      "outputs": [
        "manual_prompt_text"
      ]
    },
    {
      "id": "import_manual_response",
      "label": "匯入手動回覆",
      "description": "讀取手動貼回的模型 JSON 回覆並驗證成 Storyboard。",
      "requires": [
        "manual_response_text"
      ],
      "outputs": [
        "validated_storyboard"
      ]
    }
  ],
  "openai_actions": [
    {
      "id": "estimate_cost",
      "label": "估算成本",
      "description": "在呼叫 OpenAI 前估算單次與月使用成本。",
      "requires": [
        "sub_genre",
        "duration",
        "model"
      ],
      "outputs": [
        "cost_estimate"
      ]
    },
    {
      "id": "generate_with_openai",
      "label": "使用 OpenAI 生成",
      "description": "透過 OpenAI API 自動生成 storyboard JSON。",
      "requires": [
        "sub_genre",
        "duration",
        "model",
        "generated_rules"
      ],
      "outputs": [
        "validated_storyboard"
      ]
    }
  ]
}
